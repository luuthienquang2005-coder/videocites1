rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net: default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Anyone can read and write videos (to view them, update views/likes, or add/edit via Seeding Panel)
    match /videos/{videoId} {
      allow read, write: if true;
    }
    
    // Anyone can read and write comments (to fetch and post comments)
    match /comments/{videoId} {
      allow read, write: if true;
    }
  }
}
